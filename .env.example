# 로컬 Supabase 컨테이너의 접속 정보는 `supabase status` 출력에서 복사.
# 이 파일은 템플릿일 뿐이며, 실제 값은 `.env.local` 에 넣는다(.gitignore 처리됨).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=

# 1 로 설정하면 /api/mcp 엔드포인트가 Streamable HTTP MCP 서버를 노출 (#43).
# 미설정/0 이면 모든 MCP 요청이 404. 외부 노출 전 신중히 활성화.
MCP_PUBLIC_ENABLED=0
